<!DOCTYPE html>
<html dir="rtl" lang="he">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>המטבח של גלעד - הזמנות</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Assistant:wght@300;400;600;700&display=swap" rel="stylesheet">
    <script src="https://maps.googleapis.com/maps/api/js?libraries=places&language=he"></script>
    
    <style>
        :root { 
            --primary-green: #2d5a27; 
            --israel-blue: #0038b8;
            --bg-color: #f5f5f0;
            --plus-green: #7ed9a2;
            --whatsapp-green: #25D366;
            --modal-bg: rgba(0,0,0,0.6);
            --status-orange: #e67e22;
            --card-bg: rgba(255, 255, 255, 0.85);
            --price-bg: #eef9f1;
        }
        
        *, *::before, *::after { box-sizing: border-box; }

        body { 
            font-family: 'Assistant', sans-serif; 
            background: var(--bg-color); 
            padding: 0; 
            margin: 0; 
            padding-bottom: 140px; 
            scroll-behavior: smooth;
        }

        .container { 
            max-width: 500px; 
            margin: auto; 
            padding: 20px 15px; 
            /* מניעת גלישה אופקית */
            overflow-x: hidden;
        }
        
        .logo-container { text-align: center; margin-bottom: 10px; position: relative; }
        .logo { width: 100px; height: 100px; object-fit: cover; border-radius: 50%; box-shadow: 0 4px 10px rgba(0,0,0,0.1); border: 3px solid white; }
        
        h2 { color: var(--primary-green); text-align: center; margin-bottom: 5px; margin-top: 10px; }

        .instagram-link { display: flex; justify-content: center; margin-bottom: 20px; text-decoration: none; }
        .instagram-icon { width: 30px; height: 30px; }
        
        /* ===== TABS — גלילה חלקה במובייל ===== */
        .tabs-container { 
            display: flex; 
            gap: 8px; 
            margin-bottom: 20px; 
            overflow-x: auto; 
            padding-bottom: 8px;
            /* גלילה חלקה ב-iOS */
            -webkit-overflow-scrolling: touch;
            /* הסרת scrollbar מ-desktop */
            scrollbar-width: none;
        }
        .tabs-container::-webkit-scrollbar { display: none; }

        .tab-btn { 
            background: white; 
            border: 2px solid #ddd; 
            /* touch target מינימלי 44px */
            padding: 11px 16px; 
            border-radius: 25px; 
            cursor: pointer; 
            white-space: nowrap; 
            font-weight: bold; 
            color: #666; 
            flex-shrink: 0;
            transition: 0.3s; 
            position: relative;
            font-size: 0.9rem;
            /* מניעת double-tap zoom ב-iOS */
            touch-action: manipulation;
        }
        .tab-btn.active { background: var(--primary-green); color: white; border-color: var(--primary-green); }
        
        .status-badge {
            position: absolute; top: -8px; left: 0; background: var(--status-orange); color: white;
            font-size: 0.65rem; padding: 2px 7px; border-radius: 10px; border: 1px solid white;
        }

        .tab-content { display: none; }
        .unavailable-notice {
            background: #fff9f2; border: 1px dashed var(--status-orange); color: #d35400;
            text-align: center; padding: 12px; border-radius: 12px; margin-bottom: 15px; font-weight: bold;
        }
        .disabled-content { opacity: 0.5; pointer-events: none; filter: grayscale(0.3); }

        /* ===== PRODUCT CARDS ===== */
        .product-card { 
            background: var(--card-bg); 
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-radius: 20px; 
            padding: 12px; 
            margin-bottom: 12px; 
            box-shadow: 0 10px 25px rgba(0,0,0,0.05); 
            border: 1px solid rgba(255, 255, 255, 0.5); 
            display: flex; 
            justify-content: space-between; 
            align-items: center;
            gap: 8px;
            transition: transform 0.2s ease;
            position: relative;
            /* מניעת גלישה של תוכן */
            min-width: 0;
        }
        .product-card:active { transform: scale(0.97); }

        @keyframes shake {
            0% { transform: translateX(0); }
            25% { transform: translateX(-5px); }
            50% { transform: translateX(5px); }
            75% { transform: translateX(-5px); }
            100% { transform: translateX(0); }
        }
        .shake-effect { animation: shake 0.4s ease-in-out; }

        .sold-out-badge {
            position: absolute; top: 10px; left: 10px; background: var(--status-orange); color: white;
            font-size: 0.75rem; padding: 4px 10px; border-radius: 12px; font-weight: bold; z-index: 5;
        }

        .product-thumb {
            width: 60px; 
            height: 60px; 
            border-radius: 12px; 
            object-fit: cover;
            /* לא flex-shrink כברירת מחדל — מאפשרים לכרטיס להיות גמיש */
            flex-shrink: 0;
            cursor: zoom-in; 
            border: 1px solid #eee;
        }

        /* במסכים קטנים מאוד — תמונה קצת יותר קטנה */
        @media (max-width: 360px) {
            .product-thumb { width: 50px; height: 50px; }
        }

        .product-info { 
            flex: 1; 
            padding-right: 4px;
            /* חשוב: מניעת overflow בשם המוצר */
            min-width: 0;
        }
        
        .product-name { 
            margin: 0; 
            font-size: 1rem; 
            color: var(--primary-green); 
            font-weight: 700; 
            display: flex; 
            align-items: center; 
            gap: 5px;
            /* גלישת טקסט ארוך */
            word-break: break-word;
        }
        .product-description { margin: 4px 0; font-size: 0.82rem; color: #7f8c8d; line-height: 1.3; }
        
        .price-tag { 
            display: inline-block;
            background: var(--price-bg);
            color: var(--primary-green);
            padding: 4px 12px;
            border-radius: 12px;
            font-size: 0.9rem;
            font-weight: 700; 
            margin-top: 6px;
            border: 1px solid rgba(45, 90, 39, 0.1);
        }

        /* ===== QUANTITY CONTROLS ===== */
        .quantity-controls { 
            display: flex; 
            align-items: center; 
            gap: 6px; 
            background: #ececec; 
            padding: 5px; 
            border-radius: 30px; 
            flex-shrink: 0;
        }
        .qty-btn { 
            width: 36px; 
            height: 36px; 
            border-radius: 50%; 
            border: none; 
            background: white; 
            font-size: 20px; 
            font-weight: bold; 
            cursor: pointer; 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
            touch-action: manipulation;
            /* touch target מינימלי */
            min-width: 36px;
        }
        .qty-btn.plus { background: var(--plus-green); color: white; }
        .prod-qty { 
            width: 28px; 
            text-align: center; 
            border: none; 
            background: transparent; 
            font-size: 16px; 
            font-weight: bold;
            /* מניעת zoom ב-iOS על input */
            font-size: max(16px, 1em);
        }

        /* ===== IMAGE MODAL ===== */
        #imageModal {
            display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.85); z-index: 3000; align-items: center; justify-content: center;
        }
        #imageModal img { 
            max-width: 90%; 
            max-height: 80vh; 
            border-radius: 15px; 
            box-shadow: 0 0 20px rgba(0,0,0,0.5); 
        }
        .close-img-modal { 
            position: absolute; top: 20px; right: 20px; color: white; font-size: 35px; cursor: pointer; font-weight: bold; 
            /* touch target */
            padding: 10px;
        }

        /* ===== FORM SECTION ===== */
        .form-section { background: white; padding: 20px; border-radius: 20px; margin-top: 25px; border: 1px solid #eee; }
        label { display: block; margin-top: 15px; font-weight: bold; color: var(--primary-green); }
        
        /* שדות שם — עמודה אחת במסכים קטנים */
        .name-fields { 
            display: flex; 
            gap: 10px; 
        }
        @media (max-width: 360px) {
            .name-fields { flex-direction: column; gap: 0; }
        }

        input[type="text"], input[type="tel"], input[type="email"] { 
            width: 100%; 
            padding: 12px; 
            border: 1px solid #ddd; 
            border-radius: 10px; 
            box-sizing: border-box; 
            /* font-size 16px+ מונע zoom ב-iOS */
            font-size: 16px; 
            margin: 8px 0; 
            font-family: inherit; 
        }
        
        input:disabled { background-color: #f2f2f2; opacity: 0.5; }
        .delivery-info-text { background: #f0f7ef; padding: 12px; border-radius: 10px; border: 1px solid #e0e0e0; margin-top: 8px; font-weight: 500; }
        .invoice-toggle { color: var(--primary-green); text-decoration: underline; cursor: pointer; font-size: 0.9rem; display: inline-block; margin-top: 15px; font-weight: bold; }
        .invoice-fields { display: none; background: #fafafa; padding: 15px; border-radius: 12px; margin-top: 10px; border: 1px dashed #ccc; }
        
        .input-with-icon { position: relative; display: flex; align-items: center; }
        .input-with-icon img { position: absolute; right: 12px; width: 20px; height: 20px; pointer-events: none; }
        .input-with-icon input { padding-right: 40px; }

        .radio-card { 
            display: flex; align-items: center; padding: 12px; background: #f9f9f9; 
            border: 2px solid #eee; border-radius: 12px; cursor: pointer; margin-bottom: 8px;
            touch-action: manipulation;
        }
        .radio-card:has(input:checked) { border-color: var(--primary-green); background: #f0f7ef; }
        .radio-card input { margin-left: 10px; width: 18px; height: 18px; flex-shrink: 0; }

        /* ===== כפתור שלח הזמנה + אנימציה ===== */
        .submit-btn {
            background: var(--primary-green); 
            color: white; 
            border: none; 
            padding: 18px; 
            width: 100%; 
            border-radius: 15px; 
            cursor: pointer; 
            font-size: 1.2rem; 
            font-weight: bold; 
            margin-top: 20px;
            font-family: inherit;
            position: relative;
            overflow: hidden;
            transition: background 0.3s, transform 0.15s;
            touch-action: manipulation;
            /* שמירת גובה קבוע בזמן אנימציה */
            min-height: 58px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }
        .submit-btn:active:not(:disabled) { transform: scale(0.97); }
        .submit-btn:disabled {
            background: #5a8f55;
            cursor: not-allowed;
        }

        /* Ripple effect */
        .submit-btn::after {
            content: '';
            position: absolute;
            width: 0; height: 0;
            background: rgba(255,255,255,0.35);
            border-radius: 50%;
            transform: translate(-50%, -50%);
            transition: width 0.5s ease, height 0.5s ease, opacity 0.5s ease;
            opacity: 0;
            pointer-events: none;
            left: 50%; top: 50%;
        }
        .submit-btn.ripple::after {
            width: 500px; height: 500px;
            opacity: 0;
        }

        /* ספינר */
        @keyframes spin {
            to { transform: rotate(360deg); }
        }
        .spinner {
            display: none;
            width: 22px;
            height: 22px;
            border: 3px solid rgba(255,255,255,0.4);
            border-top-color: white;
            border-radius: 50%;
            animation: spin 0.7s linear infinite;
            flex-shrink: 0;
        }

        /* אנימציית pulse על הכפתור כשהוא בsending */
        @keyframes pulse-green {
            0%, 100% { box-shadow: 0 0 0 0 rgba(45,90,39,0.4); }
            50% { box-shadow: 0 0 0 10px rgba(45,90,39,0); }
        }
        .submit-btn.sending {
            animation: pulse-green 1.2s ease-in-out infinite;
        }

        /* ===== FLOATING FOOTER ===== */
        .floating-footer { 
            position: fixed; 
            bottom: env(safe-area-inset-bottom, 20px);
            bottom: 20px;
            left: 50%; 
            transform: translateX(-50%); 
            /* רוחב מותאם עם padding בצדדים */
            width: calc(100% - 30px);
            max-width: 460px; 
            background: var(--primary-green); 
            color: white; 
            padding: 12px 18px; 
            border-radius: 40px; 
            display: flex; 
            justify-content: space-between; 
            align-items: center;
            box-shadow: 0 10px 25px rgba(0,0,0,0.3); 
            z-index: 1000; 
            font-weight: bold;
            border: 2px solid rgba(255,255,255,0.2);
        }
        .footer-price { font-size: 1.1rem; }
        .footer-action-btn { 
            background: white; 
            color: var(--primary-green); 
            border: none; 
            padding: 10px 16px; 
            border-radius: 20px; 
            font-size: 0.9rem; 
            font-weight: bold; 
            cursor: pointer; 
            transition: 0.2s;
            touch-action: manipulation;
            white-space: nowrap;
            flex-shrink: 0;
        }
        .footer-action-btn:active { transform: scale(0.9); }

        /* ===== WHATSAPP BTN ===== */
        .whatsapp-float {
            position: fixed; 
            bottom: 95px; 
            left: 20px;
            /* safe area ב-iPhone עם notch */
            bottom: calc(env(safe-area-inset-bottom, 0px) + 95px);
            background-color: var(--whatsapp-green); 
            color: white;
            border-radius: 50px; 
            width: 56px; 
            height: 56px; 
            display: flex; 
            align-items: center; 
            justify-content: center;
            text-decoration: none; 
            box-shadow: 2px 4px 15px rgba(0,0,0,0.2); 
            z-index: 1001;
        }

        /* ===== ORDER CONFIRMATION MODAL ===== */
        .modal-overlay {
            display: none; 
            position: fixed; 
            top: 0; left: 0; 
            width: 100%; height: 100%;
            background: var(--modal-bg); 
            z-index: 2000; 
            align-items: center; 
            justify-content: center; 
            padding: 15px;
        }
        .modal-card {
            background: white; 
            width: 100%; 
            max-width: 400px; 
            border-radius: 25px; 
            padding: 25px;
            text-align: right; 
            box-shadow: 0 10px 30px rgba(0,0,0,0.2); 
            border-top: 10px solid var(--primary-green);
            /* גלילה אם המודל גדול מהמסך */
            max-height: 90vh;
            overflow-y: auto;
        }
        .confirm-btn { 
            background: var(--primary-green); 
            color: white; 
            border: none; 
            padding: 18px; 
            width: 100%; 
            border-radius: 15px; 
            cursor: pointer; 
            font-size: 1.1rem; 
            font-weight: bold; 
            margin-top: 20px;
            font-family: inherit;
            touch-action: manipulation;
            position: relative;
            min-height: 56px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }
        .confirm-btn .spinner { display: none; }
        .confirm-btn.sending .spinner { display: block; }
        .confirm-btn.sending { opacity: 0.85; cursor: not-allowed; }

        /* ===== סוכר קטן: הצלחה ===== */
        @keyframes checkmark-pop {
            0% { transform: scale(0); opacity: 0; }
            70% { transform: scale(1.2); opacity: 1; }
            100% { transform: scale(1); opacity: 1; }
        }
        .success-checkmark {
            display: none;
            font-size: 2.5rem;
            animation: checkmark-pop 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
            text-align: center;
        }
    </style>
</head>
<body>

<div id="imageModal" onclick="this.style.display='none'">
    <span class="close-img-modal">&times;</span>
    <img id="enlargedImg" src="" alt="תמונה מוגדלת">
</div>

<a href="https://wa.me/972552421009" class="whatsapp-float" target="_blank" aria-label="פנה אלינו בוואטסאפ">
    <svg width="32" height="32" fill="white" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.417-.003 6.557-5.338 11.892-11.893 11.892-1.997-.001-3.951-.5-5.688-1.448l-6.305 1.652zm6.599-3.835c1.406.836 2.971 1.277 4.568 1.277h.005c5.338 0 9.683-4.346 9.685-9.685.001-2.586-1.007-5.017-2.841-6.852-1.834-1.834-4.267-2.842-6.853-2.842-5.337 0-9.682 4.346-9.684 9.685-.001 1.716.452 3.39 1.311 4.877l-.967 3.535 3.626-.951zm10.741-6.73c-.292-.146-1.727-.853-1.995-.951-.267-.098-.462-.146-.657.146-.195.293-.755.951-.926 1.146-.171.195-.341.219-.633.073-.292-.146-1.234-.454-2.35-1.448-.869-.775-1.456-1.732-1.626-2.025-.171-.292-.018-.45.128-.595.132-.131.292-.341.439-.512.146-.171.195-.293.292-.488.098-.195.049-.366-.024-.512-.073-.146-.657-1.583-.901-2.171-.238-.571-.479-.494-.657-.503-.17-.008-.365-.01-.56-.01s-.512.073-.78.366c-.268.293-1.023 1-1.023 2.439s1.048 2.829 1.194 3.025c.146.195 2.064 3.152 5.003 4.415.699.301 1.244.481 1.67.617.702.223 1.341.192 1.845.116.563-.085 1.727-.707 1.972-1.39.244-.683.244-1.268.171-1.39-.073-.122-.268-.195-.56-.341z"/></svg>
</a>

<div id="modalOverlay" class="modal-overlay">
    <div class="modal-card">
        <h3 style="color:var(--primary-green); margin-top:0;">סיכום הזמנה</h3>
        <p><strong>לקוח:</strong> <span id="modalCustName"></span></p>
        <p><strong>כתובת:</strong> <span id="modalAddress"></span></p>
        <ul id="modalProductList" style="list-style:none; padding:0; border-top:1px solid #eee; border-bottom:1px solid #eee; padding:10px 0;"></ul>
        <p><strong>אמצעי תשלום:</strong> <span id="modalPayMethod"></span></p>
        <p style="font-size:1.2rem; color:#27ae60; font-weight:bold;">סה"כ: <span id="modalTotal"></span> ₪</p>
        <button class="confirm-btn" id="finalConfirmBtn" onclick="executeFinalSend()">
            <span class="spinner" id="confirmSpinner"></span>
            <span id="confirmBtnText">אשר ושלח</span>
        </button>
        <button onclick="closeModal()" id="backEditBtn" style="width:100%; background:none; border:none; color:gray; margin-top:15px; cursor:pointer; font-size:1rem; padding:10px; touch-action:manipulation;">חזור לעריכה</button>
    </div>
</div>

<div class="container">
    <div class="logo-container">
        <img src="לוגו המטבח של גלעד.jpg" alt="לוגו" class="logo">
    </div>
    <h2>המטבח של גלעד</h2>

    <a href="https://www.instagram.com/gilads.kitchen" target="_blank" class="instagram-link" aria-label="עמוד האינסטגרם שלנו">
        <img src="https://upload.wikimedia.org/wikipedia/commons/a/a5/Instagram_icon.png" alt="Instagram" class="instagram-icon">
    </a>
    
    <div class="tabs-container">
        <button class="tab-btn active" onclick="openTab(event, 'pickles')">חמוצים 🥒</button>
        <button class="tab-btn" onclick="openTab(event, 'soups')">מרקים <span class="status-badge">בהפוגה...</span></button>
        <button class="tab-btn" onclick="openTab(event, 'pastries')">מאפים ותוספות <span class="status-badge">בהפוגה...</span></button>
    </div>

    <div id="pickles" class="tab-content" style="display:block;">
        <div class="product-card">
            <img src="Hamburger_ready.jpg" class="product-thumb" alt="Hamburger ready" onclick="openImage(this.src)">
            <div class="product-info"><h3 class="product-name">Hamburger ready פרוסות מלפפון חמוץ</h3><p class="product-description">מושלם למנגל! צנצנת 580 מ"ל</p><span class="price-tag">₪30</span></div>
            <div class="quantity-controls"><button class="qty-btn" onclick="changeQty(this, -1)" aria-label="הפחת">-</button><input type="number" class="prod-qty" data-price="30" data-name='Hamburger ready פרוסות מלפפון חמוץ' value="0" readonly><button class="qty-btn plus" onclick="changeQty(this, 1)" aria-label="הוסף">+</button></div>
        </div>
        <div class="product-card">
            <img src="Pickels.jpg" class="product-thumb" alt="מלפפון חמוץ" onclick="openImage(this.src)">
            <div class="product-info"><h3 class="product-name">מלפפון חמוץ</h3><p class="product-description">580 מ"ל</p><span class="price-tag">₪28</span></div>
            <div class="quantity-controls"><button class="qty-btn" onclick="changeQty(this, -1)" aria-label="הפחת">-</button><input type="number" class="prod-qty" data-price="28" data-name="מלפפון חמוץ" value="0" readonly><button class="qty-btn plus" onclick="changeQty(this, 1)" aria-label="הוסף">+</button></div>
        </div>
        <div class="product-card">
            <div class="sold-out-badge">אזל זמנית</div>
            <img src="cabbage.jpg" class="product-thumb" alt="כרוב כבוש" onclick="openImage(this.src)">
            <div class="product-info"><h3 class="product-name">כרוב כבוש מותסס</h3><p class="product-description">580 מ"ל</p><span class="price-tag">₪25</span></div>
            <div class="quantity-controls"><button class="qty-btn" onclick="changeQty(this, -1)" aria-label="הפחת">-</button><input type="number" class="prod-qty" data-price="25" data-name="כרוב כבוש מותסס" value="0" readonly><button class="qty-btn plus" onclick="changeQty(this, 1)" aria-label="הוסף">+</button></div>
        </div>
        <div class="product-card">
            <img src="onion.JPG" class="product-thumb" alt="בצל סגול" onclick="openImage(this.src)">
            <div class="product-info"><h3 class="product-name">בצל סגול מוחמץ</h3><p class="product-description">250 גר'</p><span class="price-tag">₪17</span></div>
            <div class="quantity-controls"><button class="qty-btn" onclick="changeQty(this, -1)" aria-label="הפחת">-</button><input type="number" class="prod-qty" data-price="17" data-name="בצל סגול מוחמץ" value="0" readonly><button class="qty-btn plus" onclick="changeQty(this, 1)" aria-label="הוסף">+</button></div>
        </div>
        <div class="product-card">
            <img src="mustard.JPG" class="product-thumb" alt="חרדל" onclick="openImage(this.src)">
            <div class="product-info"><h3 class="product-name">ממרח חרדל מותסס</h3><p class="product-description">פיקנטי - 150 גר'</p><span class="price-tag">₪12</span></div>
            <div class="quantity-controls"><button class="qty-btn" onclick="changeQty(this, -1)" aria-label="הפחת">-</button><input type="number" class="prod-qty" data-price="12" data-name="ממרח חרדל מותסס" value="0" readonly><button class="qty-btn plus" onclick="changeQty(this, 1)" aria-label="הוסף">+</button></div>
        </div>
        <div class="product-card">
            <img src="Torshi.jpg" class="product-thumb" alt="טורשי" onclick="openImage(this.src)">
            <div class="product-info"><h3 class="product-name">חמוצים עיראקים</h3><p class="product-description">2 ליטר</p><span class="price-tag">₪30</span></div>
            <div class="quantity-controls"><button class="qty-btn" onclick="changeQty(this, -1)" aria-label="הפחת">-</button><input type="number" class="prod-qty" data-price="30" data-name="חמוצים עיראקים" value="0" readonly><button class="qty-btn plus" onclick="changeQty(this, 1)" aria-label="הוסף">+</button></div>
        </div>
    </div>

    <div id="soups" class="tab-content">
        <div class="unavailable-notice">המחלקה בהפוגה זמנית ותחזור בקרוב</div>
        <div class="disabled-content">
            <div class="product-card"><div class="product-info"><h3 class="product-name">מרק עגבניות סמיך</h3><p class="product-description">חצי ליטר</p><span class="price-tag">₪35</span></div><div class="quantity-controls"><button class="qty-btn">-</button><input type="number" class="prod-qty" value="0" readonly><button class="qty-btn plus">+</button></div></div>
        </div>
    </div>

    <div id="pastries" class="tab-content">
        <div class="unavailable-notice">המחלקה בהפוגה זמנית ותחזור בקרוב</div>
        <div class="disabled-content">
            <div class="product-card"><div class="product-info"><h3 class="product-name">קוגל ירושלמי</h3><p class="product-description">בתבנית אינגליש קייק</p><span class="price-tag">₪24</span></div><div class="quantity-controls"><button class="qty-btn">-</button><input type="number" class="prod-qty" value="0" readonly><button class="qty-btn plus">+</button></div></div>
        </div>
    </div>

    <div id="orderFormStart"></div>
    <div class="form-section">
        <label>פרטי לקוח להזמנה *</label>
        <div class="name-fields">
            <input type="text" id="firstName" placeholder="שם פרטי *" required autocomplete="given-name">
            <input type="text" id="lastName" placeholder="שם משפחה *" required autocomplete="family-name">
        </div>
        <input type="tel" id="phone" placeholder="מספר טלפון *" required maxlength="11" oninput="formatPhone(this)" autocomplete="tel">

        <label>משלוחים חינם<br>
        נא לרשום כתובת: *</label>
        <input type="text" id="address" placeholder="רחוב, מספר בית ועיר *" required autocomplete="street-address">

        <label>אמצעי תשלום:</label>
        <div class="radio-group">
            <label class="radio-card"><input type="radio" name="payMethod" value="לינק לביט" checked> <span>שלח לינק לביט</span></label>
            <label class="radio-card"><input type="radio" name="payMethod" value="לינק לפייבוקס"> <span>שלח לינק לפייבוקס</span></label>
            <label class="radio-card"><input type="radio" name="payMethod" value="מזומן"> <span>מזומן</span></label>
        </div>

        <span class="invoice-toggle" onclick="toggleInvoice()">אופן שליחת קבלה ▼</span>
        <div id="invoiceFields" class="invoice-fields">
            <div class="input-with-icon">
                <input type="email" id="invEmail" placeholder="אימייל למשלוח" oninput="handleInv('email')" autocomplete="email">
                <img src="https://upload.wikimedia.org/wikipedia/commons/7/7e/Gmail_icon_%282020%29.svg" alt="Gmail">
            </div>
            <div class="input-with-icon">
                <input type="tel" id="invWA" placeholder="וואטסאפ למשלוח" maxlength="11" oninput="handleInv('wa'); formatPhone(this)" autocomplete="tel">
                <img src="https://upload.wikimedia.org/wikipedia/commons/6/6b/WhatsApp.svg" alt="WhatsApp">
            </div>
        </div>

        <!-- כפתור שלח עם ספינר -->
        <button class="submit-btn" id="submitBtn" onclick="prepareOrder()">
            <span class="spinner" id="submitSpinner"></span>
            <span id="submitBtnText">שלח הזמנה 📦</span>
        </button>
    </div>
</div>

<div class="floating-footer">
    <div class="footer-price">סה"כ: <span id="totalPrice">0</span> ₪</div>
    <button class="footer-action-btn" onclick="scrollToForm()">למילוי פרטים</button>
</div>

<script>
    let globalOrderData = null;

    window.onload = function() {
        const addressInput = document.getElementById('address');
        if (typeof google !== 'undefined') {
            new google.maps.places.Autocomplete(addressInput, {
                componentRestrictions: { country: 'il' },
                types: ['address']
            });
        }
    };

    function scrollToForm() {
        document.getElementById('orderFormStart').scrollIntoView({ behavior: 'smooth' });
    }

    function openImage(src) {
        document.getElementById('enlargedImg').src = src;
        document.getElementById('imageModal').style.display = 'flex';
    }

    function formatPhone(input) {
        let val = input.value.replace(/\D/g, ''); 
        if (val.length > 3) val = val.substring(0, 3) + '-' + val.substring(3, 10);
        input.value = val;
    }

    function openTab(e, n) { 
        document.querySelectorAll('.tab-content').forEach(t => t.style.display='none');
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        document.getElementById(n).style.display='block'; 
        if(e.target.classList.contains('tab-btn')) e.target.classList.add('active');
        else e.target.parentElement.classList.add('active');
    }

    function changeQty(b, d) {
        let i = b.parentElement.querySelector('.prod-qty');
        let card = b.closest('.product-card');
        let oldVal = parseInt(i.value);
        let newVal = Math.max(0, oldVal + d);
        i.value = newVal;
        
        if (oldVal > 0 && newVal === 0) {
            card.classList.add('shake-effect');
            setTimeout(() => card.classList.remove('shake-effect'), 400);
        }
        
        updateTotal();
    }

    function updateTotal() {
        let t = 0; 
        document.querySelectorAll('.prod-qty').forEach(i => {
            if(i.dataset.price) t += i.value * i.dataset.price;
        });
        document.getElementById('totalPrice').innerText = t;
    }

    function toggleInvoice() { 
        let f = document.getElementById('invoiceFields'); 
        f.style.display = f.style.display === 'block' ? 'none' : 'block'; 
    }

    function handleInv(s) {
        const e = document.getElementById('invEmail'), w = document.getElementById('invWA');
        if(s==='email') w.disabled = e.value.length > 0;
        else e.disabled = w.value.length > 0;
    }

    /* ===== אנימציית כפתור שלח הזמנה ===== */
    function setSubmitLoading(isLoading) {
        const btn = document.getElementById('submitBtn');
        const spinner = document.getElementById('submitSpinner');
        const text = document.getElementById('submitBtnText');

        if (isLoading) {
            btn.disabled = true;
            btn.classList.add('sending');
            spinner.style.display = 'block';
            text.textContent = 'בודק פרטים...';
        } else {
            btn.disabled = false;
            btn.classList.remove('sending');
            spinner.style.display = 'none';
            text.textContent = 'שלח הזמנה 📦';
        }
    }

    function prepareOrder() {
        // הפעלת אנימציה מיידית
        setSubmitLoading(true);

        // קצת השהיה כדי שהמשתמש יראה את האנימציה
        setTimeout(() => {
            const fn = document.getElementById('firstName').value.trim(), 
                  ln = document.getElementById('lastName').value.trim(), 
                  p = document.getElementById('phone').value, 
                  addr = document.getElementById('address').value.trim(),
                  t = document.getElementById('totalPrice').innerText;

            if(!fn || !ln || p.replace(/\D/g, '').length < 9 || !addr || t == "0") {
                setSubmitLoading(false);
                alert("נא למלא פרטים (כולל כתובת) ולבחור מוצרים.");
                return;
            }
            
            let items = [], list = "";
            document.querySelectorAll('.prod-qty').forEach(i => {
                if(i.value > 0 && i.dataset.name) {
                    items.push(`${i.dataset.name} (${i.value})`);
                    list += `<li style="display:flex; justify-content:space-between; margin-bottom:5px;"><span>${i.dataset.name} x ${i.value}</span><span>₪${i.value * i.dataset.price}</span></li>`;
                }
            });

            let invoiceVal = "לא צוין";
            const email = document.getElementById('invEmail').value;
            const wa = document.getElementById('invWA').value;
            if(email) invoiceVal = "מייל: " + email;
            else if(wa) invoiceVal = "וואטסאפ: " + wa;

            globalOrderData = {
                date: new Date().toLocaleString('he-IL'),
                name: fn + " " + ln,
                phone: p,
                address: addr,
                orderSummary: items.join(", "),
                totalPrice: t,
                paymentMethod: document.querySelector('input[name="payMethod"]:checked').value,
                invoice: invoiceVal 
            };

            document.getElementById('modalCustName').innerText = globalOrderData.name;
            document.getElementById('modalAddress').innerText = globalOrderData.address;
            document.getElementById('modalProductList').innerHTML = list;
            document.getElementById('modalPayMethod').innerText = globalOrderData.paymentMethod;
            document.getElementById('modalTotal').innerText = t;
            document.getElementById('modalOverlay').style.display = 'flex';

            // איפוס כפתור אחרי פתיחת מודל
            setSubmitLoading(false);
        }, 500);
    }

    function closeModal() { 
        document.getElementById('modalOverlay').style.display = 'none'; 
    }

    function executeFinalSend() {
        const btn = document.getElementById('finalConfirmBtn');
        const spinner = document.getElementById('confirmSpinner');
        const text = document.getElementById('confirmBtnText');
        const backBtn = document.getElementById('backEditBtn');

        // אנימציית שליחה במודל
        btn.classList.add('sending');
        btn.disabled = true;
        spinner.style.display = 'block';
        text.textContent = 'שולח הזמנה...';
        backBtn.style.display = 'none';
        
        const scriptURL = 'https://script.google.com/macros/s/AKfycbxpOqMmDFjHLElFUZmByemI4t0DTYdkhdK7_Q1VoMtIHjGqnbHm7F8FrTGZfPBJhuLpYw/exec';
        
        fetch(scriptURL, { method: 'POST', mode: 'no-cors', body: JSON.stringify(globalOrderData) })
        .then(() => {
            // הצגת ✅ הצלחה לרגע לפני reload
            spinner.style.display = 'none';
            text.textContent = '✅ ההזמנה נשלחה!';
            btn.style.background = '#27ae60';
            setTimeout(() => {
                closeModal();
                location.reload();
            }, 1200);
        }).catch(() => { 
            btn.classList.remove('sending');
            btn.disabled = false;
            spinner.style.display = 'none';
            text.textContent = 'אשר ושלח';
            backBtn.style.display = '';
            alert("שגיאה בשליחה, נסה שנית.");
        });
    }
</script>
</body>
</html>
